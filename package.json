{
  "private": true,
  "type": "module",
  "scripts": {
    "format": "bunx --bun oxfmt src scripts",
    "schema-format": "prisma format",
    "lint": "bunx --bun oxlint src scripts",
    "lint:without-tests": "bunx --bun oxlint src scripts --ignore-pattern \"*.test.ts\"",
    "validate-yaml": "yaml-validator resources/*.yaml",
    "test": "bun test src scripts",
    "checks": "bun run format && bun run schema-format && bun run lint:without-tests && bun run lint && bun run validate-yaml && bun test",
    "migrate": "prisma migrate dev",
    "tasks": "task-master list --status=pending,in-progress,review,deferred --with-subtasks",
    "run-dev": "bun src/index.ts",
    "prisma-studio": "prisma studio",
    "install-prod": "bun install --production --frozen-lockfile",
    "migrate-prod": "prisma migrate deploy"
  },
  "dependencies": {
    "@langchain/classic": "^1.0.24",
    "@langchain/core": "1.1.33",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/openai": "^1.3.0",
    "@prisma/client": "^7.5.0",
    "@sentry/node": "^10.44.0",
    "@synapsenwerkstatt/prisma-bun-sqlite-adapter": "^1.2.2",
    "cheerio": "^1.2.0",
    "inversify": "^8.1.0",
    "inversify-inject-decorators": "^3.1.0",
    "langchain": "^1.2.34",
    "octokit": "^5.0.5",
    "reflect-metadata": "^0.2.2",
    "telegraf": "^4.16.3",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "prisma": "^7.5.0",
    "task-master-ai": "^0.43.0",
    "typescript": "^5.9.3",
    "yaml-validator": "^5.1.0"
  }
}
